{
  "name": "spear",
  "version": "0.1.0",
  "description": "Local, Matrix-themed personal project-tracking dashboard with an LLM execution-flow planner",
  "type": "module",
  "bin": {
    "spear": "dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build",
    "build:server": "tsc -p tsconfig.json",
    "build:web": "vite build",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "screenshots": "bash scripts/make-screenshots.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@fastify/static": "^8.0.0",
    "better-sqlite3": "^12.0.0",
    "commander": "^14.0.0",
    "fastify": "^5.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "playwright": "^1.60.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.4.3",
    "vitest": "^2.1.0"
  }
}
