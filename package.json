{
  "name": "spear",
  "version": "0.1.6",
  "description": "Local, Matrix-themed personal project-tracking dashboard with an LLM execution-flow planner",
  "type": "module",
  "main": "electron/main.cjs",
  "bin": {
    "spear": "dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build",
    "build:server": "tsc -p tsconfig.json",
    "build:web": "vite build",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "screenshots": "bash scripts/make-screenshots.sh",
    "electron:dev": "npm run build && electron .",
    "dist:mac": "npm run build && electron-builder --mac",
    "postdist:mac": "npm rebuild better-sqlite3",
    "dist:win": "npm run build && electron-builder --win",
    "postdist:win": "npm rebuild better-sqlite3",
    "dist": "npm run build && electron-builder --mac --win",
    "postdist": "npm rebuild better-sqlite3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@fastify/static": "^8.0.0",
    "better-sqlite3": "^12.0.0",
    "commander": "^14.0.0",
    "electron-updater": "^6.3.9",
    "fastify": "^5.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "playwright": "^1.60.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.4.3",
    "vitest": "^2.1.0"
  },
  "overrides": {
    "node-gyp": "^10.2.0"
  },
  "build": {
    "appId": "ai.riverline.spear",
    "productName": "spear",
    "asar": false,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "npmRebuild": true,
    "publish": {
      "provider": "github",
      "owner": "aryanpandey",
      "repo": "spear"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity",
      "icon": "build/icon.png",
      "identity": null
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.png"
    }
  }
}
